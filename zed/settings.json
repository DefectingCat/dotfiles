// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ssh_connections": [
    {
      "host": "api.rua.plus",
      "username": "ubuntu",
      "port": 29888,
      "args": [],
      "projects": [
        {
          "paths": ["/home/ubuntu"]
        }
      ]
    }
  ],
  "git": {
    "inline_blame": {
      "enabled": false
    }
  },
  "disable_ai": true,
  "icon_theme": {
    "mode": "system",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha"
  },
  "restore_on_startup": "none",
  "collaboration_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "git_panel": {
    "sort_by_path": true,
    "dock": "right"
  },
  "project_panel": {
    "dock": "right"
  },
  "vim_mode": true,
  "terminal": {
    "font_size": 16.0,
    "font_family": "Maple Mono Normal NF CN",
    "blinking": "on"
  },
  "preview_tabs": {
    "enabled": false
  },
  "status_bar": {
    "experimental.show": true
  },
  "tab_bar": {
    "show": false
  },
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true
  },
  "minimap": {
    "show": "never"
  },
  "cursor_blink": true,
  "autosave": "off",
  "buffer_font_family": "Maple Mono Normal NF CN",
  "file_types": {
    "jsonc": ["*.json"],
    "Shell Script": ["sh", "bash", "env", "conf", "yarn.lock"]
  },
  "linked_edits": true,
  "show_edit_predictions": true,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15.0,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Mocha (Blur) [Heavy]",
    "dark": "Catppuccin Espresso (Blur)"
  },
  "scroll_beyond_last_line": "one_page",
  "vertical_scroll_margin": 3,
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "current_line_highlight": "all",
  "inlay_hints": {
    "enabled": true
  },
  // ls -l ~/Library/Application\ Support/Zed/extensions/installed/
  "auto_install_extensions": {
    // "cargo-tom": true,
    "catppuccin": true,
    "catppuccin-blur": true,
    "catppuccin-icons": true,
    "dockerfile": true,
    "fish": true,
    "git-firefly": true,
    "html": true,
    "less": true,
    "make": true,
    "tombi": true,
    "toml": true
  },
  "file_scan_exclusions": [
    "**/.git/objects",
    "**/.git/refs",
    "**/.git/logs",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings"
  ],
  "languages": {
    "Markdown": {
      "format_on_save": "on"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "allFeatures": true,
          "buildScripts": {
            "rebuildOnSave": true
          }
        },
        "procMacro": {
          "enable": true
        },
        // "checkOnSave": {
        //   "command": "clippy" // rust-analyzer.checkOnSave.command
        // },
        "checkOnSave": true,
        "hover": {
          "references": {
            "enabled": true
          }
        },
        "imports": {
          "prefix": "crate",
          "preferPrelude": true,
          "granularity": {
            "enforce": true
          }
        }
      }
    }
  }
  // "proxy": "socks5h://127.0.0.1:13659"
}
